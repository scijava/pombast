<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<link type="text/css" rel="stylesheet" href="status.css">
<link rel="icon" type="image/png" href="favicon.png">
<script type="text/javascript" src="sorttable.js"></script>
<style>
td.smelt { text-align: center; min-width: 3em; }
td.smelt.has-log { cursor: pointer; text-decoration: underline dotted; text-underline-offset: 2px; }
td.smelt.has-log:hover { filter: brightness(1.3); }
#smelt-modal { display: none; position: fixed; inset: 0; z-index: 9999; align-items: center; justify-content: center; }
#smelt-modal.open { display: flex; }
#smelt-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.5); }
#smelt-box { position: relative; z-index: 1; background: #fff; border-radius: 6px; max-width: 900px; width: 95vw; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 8px 32px rgba(0,0,0,.3); overflow: hidden; }
#smelt-header { display: flex; align-items: center; gap: .5em; padding: .6em 1em; background: #f5f5f5; border-bottom: 1px solid #ddd; }
#smelt-title { flex: 1; font-weight: bold; font-size: .95em; }
#smelt-close { background: none; border: none; color: #888; font-size: 1.4em; line-height: 1; cursor: pointer; padding: 0 .15em; flex-shrink: 0; }
#smelt-close:hover { color: #333; }
#smelt-log { margin: 0; padding: .75em 1em; overflow: auto; flex: 1; font-size: .8em; white-space: pre; }
</style>
</head>
<body>
<!-- Generated via https://codepo8.github.io/css-fork-on-github-ribbon/ -->
<span id="forkongithub"><a href="https://github.com/scijava/status.scijava.org">Fix me on GitHub</a></span>
{{ header_html | safe }}
<table class="sortable">
<tr>
{%- for column in columns %}
<th>{{ column }}</th>
{%- endfor %}
</tr>
{%- for row in rows %}
<tr class="g-{{ row.group_css }} a-{{ row.artifact_css }} {{ row.bom_css }} {{ row.release_css }}" data-ga="{{ row.ga }}">
<td>
{%- if row.project_url -%}
<a href="{{ row.project_url }}">{{ row.artifact_label }}</a>
{%- else -%}
{{ row.artifact_label }}
{%- endif -%}
</td>
<td>
{%- if row.bom_version == row.latest_version -%}
{{ row.latest_link | safe }}
{%- else -%}
{{ row.bom_link | safe }} &rarr; {{ row.latest_link | safe }}
{%- endif -%}
</td>
<td{% if row.drift.cls %} class="{{ row.drift.cls }}"{% endif %} sorttable_customkey="{{ row.drift.sort_key }}"{% if row.drift.tooltip %} title="{{ row.drift.tooltip }}"{% endif %}>{{ row.drift.html | safe }}</td>
<td sorttable_customkey="{{ row.action_key }}">{{ row.action }}</td>
{{ row.ci_html | safe }}
<td class="smelt"></td>
</tr>
{%- endfor %}
</table>
{{ footer_html | safe }}
<div id="smelt-modal">
  <div id="smelt-backdrop"></div>
  <div id="smelt-box">
    <div id="smelt-header">
      <span id="smelt-title"></span>
      <button id="smelt-close">&times;</button>
    </div>
    <pre id="smelt-log"></pre>
  </div>
</div>
<script>
(function(){
  fetch('badges.json').then(function(r){return r.json();}).then(function(d){
    var repos=d.repos||{};
    document.querySelectorAll('td.ci[data-slug]').forEach(function(td){
      var t=repos[td.dataset.slug];
      if(!t)return;
      td.setAttribute('sorttable_customkey',
        t.indexOf('passing')>=0?'1':t.indexOf('failing')>=0?'2':'3');
    });
  }).catch(function(){});
})();
(function(){
  var PASS={pass:1,prior:1,skip:1,skipped:1},FAIL={fail:1,error:1};
  function isPass(s){return !!(s&&PASS[s]);}
  function isFail(s){return !!(s&&FAIL[s]);}
  function stripAnsi(s){return s?s.replace(/\x1b\[[0-9;]*[A-Za-z]/g,''):''}
  function buildLog(c){
    var p=[];
    if(isFail(c.binary_test)&&c.binary_log)p.push('=== Binary ===\n'+stripAnsi(c.binary_log));
    if(isFail(c.source_build)&&c.source_log){
      if(p.length)p.push('\n=== Source ===\n'+stripAnsi(c.source_log));
      else p.push('=== Source ===\n'+stripAnsi(c.source_log));
    }
    return p.join('');
  }
  function showSmelt(){
    document.getElementById('smelt-title').textContent=this.dataset.ga;
    document.getElementById('smelt-log').textContent=this.dataset.log;
    document.getElementById('smelt-modal').classList.add('open');
  }
  fetch('smelt.json').then(function(r){return r.json();}).then(function(d){
    var comps=d.components||{};
    document.querySelectorAll('tr[data-ga]').forEach(function(tr){
      var c=comps[tr.dataset.ga],td=tr.querySelector('td.smelt');
      if(!td||!c)return;
      var bin=c.binary_test,src=c.source_build;
      var fail=isFail(bin)||isFail(src),pass=isPass(bin)||isPass(src);
      td.setAttribute('sorttable_customkey',fail?'1':pass?'2':'3');
      td.textContent=fail?'❌':pass?'✅':'❔';
      var log=buildLog(c);
      if(log){
        td.classList.add('has-log');
        td.dataset.log=log;
        td.dataset.ga=tr.dataset.ga;
        td.addEventListener('click',showSmelt);
      }
    });
  }).catch(function(){});
  var modal=document.getElementById('smelt-modal');
  document.getElementById('smelt-close').addEventListener('click',function(){modal.classList.remove('open');});
  document.getElementById('smelt-backdrop').addEventListener('click',function(){modal.classList.remove('open');});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')modal.classList.remove('open');});
})();
</script>
</body>
</html>
