<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<link type="text/css" rel="stylesheet" href="status.css">
<link rel="icon" type="image/png" href="favicon.png">
<script type="text/javascript" src="sorttable.js"></script>
<script src="https://cdn.jsdelivr.net/npm/ansi_up@5/ansi_up.js"></script>
<style>
td.smelt { text-align: center; min-width: 3em; }
td.smelt.has-log { cursor: pointer; text-decoration: underline dotted; text-underline-offset: 2px; }
td.smelt.has-log:hover { filter: brightness(1.3); }
#smelt-refresh { opacity: 0.8; cursor: pointer; color: #333; font-size: .9em; font-weight: bold; padding: 0 .2em 0 .2em; margin-left: 0.3em; }
#smelt-refresh:hover { opacity: 1; }
#smelt-modal { display: none; position: fixed; inset: 0; z-index: 9999; align-items: center; justify-content: center; }
#smelt-modal.open { display: flex; }
#smelt-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.5); }
#smelt-box { position: relative; z-index: 1; background: #1a1a1a; border-radius: 6px; max-width: 900px; width: 95vw; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 8px 32px rgba(0,0,0,.6); overflow: hidden; }
#smelt-header { display: flex; align-items: center; gap: .5em; padding: .6em 1em; background: #2a2a2a; border-bottom: 1px solid #444; }
#smelt-title { flex: 1; font-weight: bold; font-size: .95em; color: #e0e0e0; }
#smelt-close { background: none; border: none; color: #888; font-size: 1.4em; line-height: 1; cursor: pointer; padding: 0 .15em; flex-shrink: 0; }
#smelt-close:hover { color: #fff; }
#smelt-log { margin: 0; padding: .75em 1em; overflow: auto; flex: 1; font-size: .8em; white-space: pre; line-height: 1.4; color: #ccc; }
</style>
</head>
<body>
<!-- Generated via https://codepo8.github.io/css-fork-on-github-ribbon/ -->
<span id="forkongithub"><a href="https://github.com/scijava/status.scijava.org">Fix me on GitHub</a></span>
{{ header_html | safe }}
<table class="sortable">
<tr>
{%- for column in columns %}
<th>{{ column }}{% if column == "Smelt" %}<button id="smelt-refresh" title="Refresh smelt data" onclick="loadSmelt(true);event.stopPropagation();">&#x27F3;</button>{% endif %}</th>
{%- endfor %}
</tr>
{%- for row in rows %}
<tr class="g-{{ row.group_css }} a-{{ row.artifact_css }} {{ row.bom_css }} {{ row.release_css }}" data-ga="{{ row.ga }}">
<td>
{%- if row.project_url -%}
<a href="{{ row.project_url }}">{{ row.artifact_label }}</a>
{%- else -%}
{{ row.artifact_label }}
{%- endif -%}
</td>
<td>
{%- if row.bom_version == row.latest_version -%}
{{ row.latest_link | safe }}
{%- else -%}
{{ row.bom_link | safe }} &rarr; {{ row.latest_link | safe }}
{%- endif -%}
</td>
<td{% if row.drift.cls %} class="{{ row.drift.cls }}"{% endif %} sorttable_customkey="{{ row.drift.sort_key }}"{% if row.drift.tooltip %} title="{{ row.drift.tooltip }}"{% endif %}>{{ row.drift.html | safe }}</td>
<td sorttable_customkey="{{ row.action_key }}">{{ row.action }}</td>
{{ row.ci_html | safe }}
<td class="smelt"></td>
</tr>
{%- endfor %}
</table>
{{ footer_html | safe }}
<div id="smelt-modal">
  <div id="smelt-backdrop"></div>
  <div id="smelt-box">
    <div id="smelt-header">
      <span id="smelt-title"></span>
      <button id="smelt-close">&times;</button>
    </div>
    <pre id="smelt-log"></pre>
  </div>
</div>
<script>
(function(){
  fetch('badges.json').then(function(r){return r.json();}).then(function(d){
    var repos=d.repos||{};
    var tds=Array.from(document.querySelectorAll('td.ci[data-slug]'));
    tds.forEach(function(td,i){
      var slug=td.dataset.slug;
      var entry=repos[slug];
      var title=entry?(typeof entry==='string'?entry:entry.title):null;
      var wf=entry?(typeof entry==='string'?null:entry.workflow):null;
      if(!wf)wf=td.dataset.wf;
      if(title)td.setAttribute('sorttable_customkey',
        title.indexOf('passing')>=0?'1':title.indexOf('failing')>=0?'2':'3');
      setTimeout(function(){
        var a=document.createElement('a');
        a.href='https://github.com/'+slug+'/actions';
        var img=document.createElement('img');
        img.src='https://github.com/'+slug+'/actions/workflows/'+wf+'/badge.svg';
        a.appendChild(img);
        td.appendChild(a);
      },i*40);
    });
  }).catch(function(){});
})();
(function(){
  var PASS={pass:1,prior:1,skip:1,skipped:1},FAIL={fail:1,error:1};
  var au=new AnsiUp();
  function isPass(s){return !!(s&&PASS[s]);}
  function isFail(s){return !!(s&&FAIL[s]);}
  function buildLog(c){
    var p=[];
    if(isFail(c.binary_test)&&c.binary_log)p.push('=== Binary ===\n'+c.binary_log);
    if(isFail(c.source_build)&&c.source_log){
      if(p.length)p.push('\n=== Source ===\n'+c.source_log);
      else p.push('=== Source ===\n'+c.source_log);
    }
    return p.join('');
  }
  function showSmelt(){
    document.getElementById('smelt-title').textContent=this.dataset.ga;
    document.getElementById('smelt-log').innerHTML=au.ansi_to_html(this.dataset.log);
    document.getElementById('smelt-modal').classList.add('open');
  }
  function loadSmelt(bust){
    var url='smelt.json'+(bust?'?_='+Date.now():'');
    fetch(url).then(function(r){return r.json();}).then(function(d){
      var comps=d.components||{};
      document.querySelectorAll('tr[data-ga]').forEach(function(tr){
        var oldTd=tr.querySelector('td.smelt');
        if(!oldTd)return;
        var td=oldTd.cloneNode(false);
        oldTd.parentNode.replaceChild(td,oldTd);
        var c=comps[tr.dataset.ga];
        if(!c)return;
        var bin=c.binary_test,src=c.source_build;
        var fail=isFail(bin)||isFail(src),pass=isPass(bin)||isPass(src);
        td.setAttribute('sorttable_customkey',fail?'1':pass?'2':'3');
        td.textContent=fail?'❌':pass?'✅':'❔';
        var log=buildLog(c);
        if(log){
          td.classList.add('has-log');
          td.dataset.log=log;
          td.dataset.ga=tr.dataset.ga;
          td.addEventListener('click',showSmelt);
        }
      });
    }).catch(function(){});
  }
  window.loadSmelt=loadSmelt;
  loadSmelt();
  var modal=document.getElementById('smelt-modal');
  document.getElementById('smelt-close').addEventListener('click',function(){modal.classList.remove('open');});
  document.getElementById('smelt-backdrop').addEventListener('click',function(){modal.classList.remove('open');});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')modal.classList.remove('open');});
})();
</script>
</body>
</html>
