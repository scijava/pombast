<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<link type="text/css" rel="stylesheet" href="status.css">
<link rel="icon" type="image/png" href="favicon.png">
<script type="text/javascript" src="sorttable.js"></script>
{%- if smelt_logs_json %}
<style>
#log-modal{display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center}
#log-modal.open{display:flex}
#log-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.6)}
#log-box{position:relative;z-index:1;background:#1a1a1a;border-radius:6px;max-width:90vw;width:900px;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 12px 40px rgba(0,0,0,.7);overflow:hidden}
#log-header{display:flex;align-items:center;gap:.5em;padding:.5em .75em;background:#2a2a2a;border-bottom:1px solid #444}
#log-title{flex:1;font-family:monospace;font-size:.9em;color:#e0e0e0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#log-close{background:none;border:none;color:#888;font-size:1.4em;line-height:1;cursor:pointer;padding:0 .15em;flex-shrink:0}
#log-close:hover{color:#fff}
#log-content{margin:0;padding:1em;overflow:auto;font-family:monospace;font-size:.82em;line-height:1.5;color:#ccc;flex:1}
td.smelt-has-log{cursor:pointer;text-decoration:underline dotted;text-underline-offset:2px}
td.smelt-has-log:hover{filter:brightness(1.3)}
</style>
{%- endif %}
</head>
<body>
<script type="text/javascript" src="sortable-badges.js"></script>
<!-- Generated via https://codepo8.github.io/css-fork-on-github-ribbon/ -->
<span id="forkongithub"><a href="https://github.com/scijava/status.scijava.org">Fix me on GitHub</a></span>
{{ header_html | safe }}
<table class="sortable">
<tr>
{%- for column in columns %}
<th>{{ column }}</th>
{%- endfor %}
</tr>
{%- for row in rows %}
<tr class="g-{{ row.group_css }} a-{{ row.artifact_css }} {{ row.bom_css }} {{ row.release_css }}" data-ga="{{ row.ga }}">
<td>
{%- if row.project_url -%}
<a href="{{ row.project_url }}">{{ row.artifact_label }}</a>
{%- else -%}
{{ row.artifact_label }}
{%- endif -%}
</td>
<td>
{%- if row.bom_version == row.latest_version -%}
{{ row.latest_link | safe }}
{%- else -%}
{{ row.bom_link | safe }} &rarr; {{ row.latest_link | safe }}
{%- endif -%}
</td>
<td{% if row.drift.cls %} class="{{ row.drift.cls }}"{% endif %} sorttable_customkey="{{ row.drift.sort_key }}"{% if row.drift.tooltip %} title="{{ row.drift.tooltip }}"{% endif %}>{{ row.drift.html | safe }}</td>
<td sorttable_customkey="{{ row.action_key }}">{{ row.action }}</td>
{{ row.badge_html | safe }}
{%- if row.smelt is defined %}
<td class="{{ row.smelt.binary.css }}{% if row.smelt.version_mismatch %} smelt-stale{% endif %}{% if row.smelt.binary.has_log %} smelt-has-log{% endif %}"{% if row.smelt.binary.has_log %} data-type="binary"{% endif %}>{{ row.smelt.binary.label }}</td>
<td class="{{ row.smelt.source.css }}{% if row.smelt.version_mismatch %} smelt-stale{% endif %}{% if row.smelt.source.has_log %} smelt-has-log{% endif %}"{% if row.smelt.source.has_log %} data-type="source"{% endif %}>{{ row.smelt.source.label }}</td>
{%- endif %}
</tr>
{%- endfor %}
</table>
{{ footer_html | safe }}
{%- if smelt_logs_json %}
<div id="log-modal">
  <div id="log-backdrop"></div>
  <div id="log-box">
    <div id="log-header">
      <span id="log-title"></span>
      <button id="log-close">&times;</button>
    </div>
    <pre id="log-content"></pre>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/ansi_up@5/ansi_up.js"></script>
<script>
(function(){
  var modal = document.getElementById('log-modal');
  var titleEl = document.getElementById('log-title');
  var content = document.getElementById('log-content');
  var au = new AnsiUp();
  var LOGS = {{ smelt_logs_json | safe }};

  function show(ga, type) {
    var log = LOGS[ga] && LOGS[ga][type];
    if (!log) return;
    titleEl.textContent = ga + ' — ' + type + ' log';
    content.innerHTML = au.ansi_to_html(log);
    modal.classList.add('open');
  }
  function hide() { modal.classList.remove('open'); }

  document.querySelectorAll('td.smelt-has-log').forEach(function(td) {
    td.addEventListener('click', function() {
      show(td.closest('tr').dataset.ga, td.dataset.type);
    });
  });
  document.getElementById('log-close').addEventListener('click', hide);
  document.getElementById('log-backdrop').addEventListener('click', hide);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') hide(); });
})();
</script>
{%- endif %}
</body>
</html>
